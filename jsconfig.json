{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "checkJs": false,
    "moduleResolution": "node",
    "target": "ES2020",
    "module": "commonjs",
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowJs": true
  },
  "include": ["src", "routes", "services", "server.js"]
} 