# Server Configuration
PORT=10000
NODE_ENV=development

# CORS Configuration
CORS_ORIGIN=https://your-frontend-url.com,http://localhost:5173,http://localhost:3000

# Database Configuration
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/nexapay?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=replace-with-your-32-char-secret

# Stellar / Soroban Configuration
STELLAR_NETWORK=testnet
STELLAR_SECRET_KEY=your_stellar_secret_key_here
SOROBAN_RPC_URL=https://soroban-rpc-testnet.stellar.org
CONTRACT_ID=your_contract_id_here
SOROBAN_WALLET_PUBLIC=your_soroban_wallet_public_here
SOROBAN_WALLET_SEED=your_soroban_wallet_seed_here
STELLAR_PUBLIC_KEY=your_stellar_public_key_here

# Platform Fee Configuration
PLATFORM_FEE_PERCENTAGE=0.1